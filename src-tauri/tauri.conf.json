{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Zephyr",
  "version": "0.1.0",
  "identifier": "com.zephyr.desktop",
  "build": {
    "beforeDevCommand": "npm run build:css",
    "beforeBuildCommand": "npm run build:css",
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Zephyr",
        "width": 860,
        "height": 620,
        "minWidth": 720,
        "minHeight": 540,
        "resizable": true,
        "fullscreen": false,
        "additionalBrowserArgs": "--disable-features=msWebOOUI,msPdfOOUI --disable-logging --log-level=3",
        "decorations": false,
        "transparent": true,
        "visible": false,
        "center": true,
        "devtools": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self' ws://127.0.0.1:* http://127.0.0.1:* https://api.github.com https://raw.githubusercontent.com https://github.com https://objects.githubusercontent.com https://mirror.ghproxy.com"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
